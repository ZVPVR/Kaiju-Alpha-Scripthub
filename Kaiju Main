local function generateID()
   local chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%^&*()-=[]{}|;\'",./\\<>?`~+_*[]#@&^%'
   local len = math.random(10, 11)
   local result = ""
   for i = 1, len do
      local idx = math.random(1, #chars)
      result = result .. chars:sub(idx, idx)
   end
   return result
end

