local isAntiStun = false
MainTab:CreateToggle({
   Name = "Anti Stun",
   Info = "Prevents you from being stunned or grabbed",
   CurrentValue = false,
   Flag = "AntiStunToggle",
   Callback = function(Value)
      isAntiStun = Value
      if Value then
         task.spawn(function()
            while isAntiStun do
               local char = game:GetService("Players").LocalPlayer.Character
               char:SetAttribute("Stunned", false)
               char:SetAttribute("Grabbed", false)
               task.wait(0)
            end
         end)
      end
   end,
})

